# 외부 API 키 템플릿. 실제 값은 .env 에 채워 넣는다.
# 키 발급처는 README 또는 docs 참조.

# 카카오 (https://developers.kakao.com)
KAKAO_NATIVE_APP_KEY=
KAKAO_REST_API_KEY=

# 알라딘 Open API (https://blog.aladin.co.kr/openapi)
ALADIN_TTB_KEY=

# 기상청 단기예보 (https://data.go.kr) — 선택 기능
KMA_SERVICE_KEY=

# Gemini (옵션 B 통합 후 미사용)
# 추천 Gemini 호출은 보조 FirebaseApp(aiApp) + firebase_ai 로 처리하므로
# 아래 키는 더 이상 필요하지 않다. 호환을 위해 라인만 주석으로 남긴다.
# GEMINI_API_KEY=